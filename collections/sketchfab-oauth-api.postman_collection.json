  "info": {
    "_postman_id": "459fd7c3-48b7-473d-9c4f-69d7d368009c",
    "name": "Sketchfab OAuth 2.0 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Sketchfab OAuth 2.0 authorization server. Supports the Authorization Code, Implicit, and Resource Owner Password Credentials grant types plus refresh token rotation. Access tokens are valid for one month; the Implicit flow does not issue refresh tokens.\n\n\nContact Support:\n Name: Sketchfab Developer Support",
      "type": "text/plain"
    }
