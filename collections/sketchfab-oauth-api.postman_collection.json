          "name": "OAuth Authorize Endpoint",
          "request": {
            "name": "OAuth Authorize Endpoint",
            "description": {
              "content": "Initiate the Authorization Code or Implicit flow. The end user is presented with the Sketchfab consent screen and on approval the browser is redirected back to the registered redirect_uri with either a `code` query parameter or an `access_token` URL fragment.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oauth2",
                "authorize",
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) `code` (Authorization Code) or `token` (Implicit)."
                },
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "Redirect URI registered with the OAuth application."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "Recommended CSRF / replay protection nonce."
                },
                {
                  "disabled": false,
                  "key": "approval_prompt",
                  "value": "<string>",
                  "description": "Set to `force` to always re-prompt the user for consent."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
