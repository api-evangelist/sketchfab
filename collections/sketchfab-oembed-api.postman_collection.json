          "name": "Retrieve oEmbed Response",
          "request": {
            "name": "Retrieve oEmbed Response",
            "description": {
              "content": "Resolve a Sketchfab model or playlist URL into an oEmbed JSON response carrying an iframe embed snippet.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oembed"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "url",
                  "value": "<uri>",
                  "description": "(Required) The full Sketchfab model or playlist URL."
                },
                {
                  "disabled": false,
                  "key": "maxwidth",
                  "value": "<integer>",
                  "description": "Maximum width of the returned viewer in pixels (the aspect ratio is always 16:9)."
                },
                {
                  "disabled": false,
                  "key": "maxheight",
                  "value": "<integer>",
                  "description": "Maximum height of the returned viewer in pixels (the aspect ratio is always 16:9)."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Response format. Only `json` is supported."
                }
              ],
              "variable": []
            },
